[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://ui/sidebar.gd" id="1"]

[node name="Sidebar" type="VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(220, 0)
script = ExtResource("1")

[node name="SessionsLabel" type="Label" parent="."]
layout_mode = 2
text = "Sessions"

[node name="SessionList" type="ItemList" parent="."]
layout_mode = 2
size_flags_vertical = 3

[node name="HSep" type="HSeparator" parent="."]
layout_mode = 2

[node name="SettingsLabel" type="Label" parent="."]
layout_mode = 2
text = "Settings"

[node name="ProviderLabel" type="Label" parent="."]
layout_mode = 2
text = "Provider:"

[node name="ProviderOpt" type="OptionButton" parent="."]
layout_mode = 2

[node name="ModelLabel" type="Label" parent="."]
layout_mode = 2
text = "Model:"

[node name="ModelInput" type="LineEdit" parent="."]
layout_mode = 2
placeholder_text = "Model name"

[node name="ApiKeyLabel" type="Label" parent="."]
layout_mode = 2
text = "API Key:"

[node name="ApiKeyInput" type="LineEdit" parent="."]
layout_mode = 2
