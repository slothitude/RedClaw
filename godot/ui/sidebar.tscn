secret = true

[node name="PermLabel" type="Label" parent="."]
layout_mode = 2
text = "Permission Mode:"

[node name="PermModeOpt" type="OptionButton" parent="."]
layout_mode = 2

[node name="HSep2" type="HSeparator" parent="."]
layout_mode = 2

[node name="AssistantLabel" type="Label" parent="."]
layout_mode = 2
text = "Assistant"

[node name="AssistantCheck" type="CheckBox" parent="."]
layout_mode = 2
text = "Assistant mode"

[node name="PersonaNameLabel" type="Label" parent="."]
layout_mode = 2
text = "Persona name:"

[node name="PersonaNameInput" type="LineEdit" parent="."]
layout_mode = 2
