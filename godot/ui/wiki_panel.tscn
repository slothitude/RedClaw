[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://ui/wiki_panel.gd" id="1"]

[node name="WikiPanel" type="VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(250, 0)
script = ExtResource("1")

[node name="Title" type="Label" parent="."]
layout_mode = 2
text = "Wiki"

[node name="QueryBar" type="HBoxContainer" parent="."]
layout_mode = 2

[node name="QueryInput" type="LineEdit" parent="QueryBar"]
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "Ask the wiki..."

[node name="QueryBtn" type="Button" parent="QueryBar"]
layout_mode = 2
text = "Ask"

[node name="StatsBtn" type="Button" parent="QueryBar"]
layout_mode = 2
text = "Stats"

[node name="ResultScroll" type="ScrollContainer" parent="."]
layout_mode = 2
size_flags_vertical = 3

[node name="ResultContent" type="RichTextLabel" parent="ResultScroll"]
layout_mode = 2
size_flags_horizontal = 3
bbcode_enabled = true
fit_content = true
scroll_following = true
custom_minimum_size = Vector2(0, 100)

[node name="StatsLabel" type="Label" parent="."]
layout_mode = 2
