[node name="BriefingNewsCheck" type="CheckBox" parent="VBox"]
text = "Include news"

[node name="BriefingTasksCheck" type="CheckBox" parent="VBox"]
text = "Include tasks"

[node name="NewsTopicsLabel" type="Label" parent="VBox"]
