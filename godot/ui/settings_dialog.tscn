[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://ui/settings_dialog.gd" id="1"]

[node name="SettingsDialog" type="AcceptDialog"]
title = "Settings"
size = Vector2i(520, 820)
script = ExtResource("1")

[node name="VBox" type="VBoxContainer" parent="."]

[node name="ProviderLabel" type="Label" parent="VBox"]
